# ═══════════════════════════════════════════════════
#  AttendX — Environment Configuration Template
#  Copy this file to .env and fill in your values:
#     copy .env.example .env
# ═══════════════════════════════════════════════════

# ─── Flask Core ───
# Generate your own: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
FLASK_ENV=development
FLASK_DEBUG=1

# ─── Seed Admin (first boot only — when DB has zero users) ───
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@attendance.local
ADMIN_PASSWORD=admin123

# ─── Database ───
DATABASE_PATH=attendance.db

# ─── Email / SMTP ───
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# ─── OTP Settings ───
OTP_EXPIRY_SECONDS=300

# ─── Dual-Key Engine ───
TOKEN_REFRESH_SECONDS=15

# ─── Audit Roulette ───
AUDIT_FLAG_PERCENT=5

# ─── Daily Digest ───
DIGEST_HOUR=8
DIGEST_MINUTE=0
